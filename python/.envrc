#!/usr/bin/env bash
# Export THINGIVERSE_TOKEN from the repo's thingi_details.env and enable nix

# Read APP_TOKEN from the parent repo file and export as THINGIVERSE_TOKEN
if [ -f ../thingi_details.env ]; then
  export THINGIVERSE_TOKEN=$(sed -n 's/^APP_TOKEN=\(.*\)$/\1/p' ../thingi_details.env)
fi

# Use the Nix shell defined in shell.nix (requires nix-direnv integration)
use nix
